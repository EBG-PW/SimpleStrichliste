<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= language.Page.Privacy %></title>
    <%- html_content.manifest %>
    <script>
      const lang = <%- JSON.stringify(language) %>;
    </script>
    <script src="<%= domain %>/libjs/i18next.js?<%= curentUnixTime %>"></script>
    <script src="<%= domain %>/libjs/tailwind.js?<%= curentUnixTime %>"></script>
  </head>
  <body class="bg-gray-100 font-sans text-gray-900">
    <main class="container mx-auto max-w-4xl p-4 md:p-8">
      <a href="/login" class="mb-6 inline-flex items-center text-sm font-semibold text-blue-600 hover:text-blue-500">
        &larr; Login
      </a>
      <section class="bg-white rounded-xl shadow-lg p-6 md:p-8">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-800" data-translate="Page.Privacy"></h1>
        <div class="prose mt-6 max-w-none text-gray-700">
          <%- legalContent.privacyHtml || '' %>
        </div>
      </section>
    </main>
    <script src="<%= domain %>/appjs/translate.js?<%= curentUnixTime %>"></script>
  </body>
</html>
