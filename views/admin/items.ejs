<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title id="pageTitle" data-translate="Items.PageTitle"></title>
    <%- html_content.manifest %>
    <script>
      const lang = <%- JSON.stringify(language) %>;
      const features = <%- JSON.stringify(features) %>;
    </script>
    <script src="<%= domain %>/libjs/i18next.js?<%= curentUnixTime %>"></script>
    <script src="<%= domain %>/libjs/tailwind.js?<%= curentUnixTime %>"></script>
    <style>
      body {
        padding-bottom: 80px;
      }
      .item-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
      }
      .item-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <%- html_content.navbar %>

    <main class="container mx-auto p-4 md:p-6">
      <header class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center md:mb-6">
        <div class="flex min-w-0 items-center">
          <a href="/admin/index" aria-label="Go back" class="mr-3 flex-shrink-0 text-gray-500 hover:text-gray-800 md:mr-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          </a>
          <h1 class="whitespace-nowrap text-lg font-bold text-gray-800 sm:text-2xl md:text-3xl" id="page-title" data-translate="Items.PageTitle"></h1>
        </div>
        <button id="open-discounts-button" type="button" class="w-full rounded-lg bg-red-600 px-4 py-2 font-semibold text-white shadow hover:bg-red-700 sm:ml-auto sm:w-auto sm:flex-shrink-0" data-translate="Items.Discounts.Manage"></button>
      </header>

      <div class="mb-6">
        <input type="search" id="search-input" data-translate-placeholder="Items.SearchPlaceholder" class="w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500" />
      </div>
      <div id="categories-container"></div>
    </main>

    <div id="discount-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
      <div id="discount-backdrop" class="absolute inset-0 bg-black/60"></div>
      <div class="relative w-full max-w-2xl overflow-hidden rounded-2xl bg-white shadow-2xl">
        <div class="flex items-center justify-between border-b p-5">
          <h2 class="text-xl font-bold" data-translate="Items.Discounts.Title"></h2>
          <button id="close-discounts-button" type="button" class="text-2xl text-gray-400 hover:text-gray-700">&times;</button>
        </div>
        <div id="discount-list" class="max-h-[60vh] divide-y overflow-y-auto"></div>
        <div class="flex items-center justify-between gap-4 border-t p-5">
          <span id="discount-status" class="text-sm text-gray-500"></span>
          <button id="notify-discounts-button" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 font-semibold text-white hover:bg-indigo-700 disabled:opacity-50" data-translate="Items.Discounts.Notify"></button>
        </div>
      </div>
    </div>

    <script src="<%= domain %>/appjs/permission.js?<%= curentUnixTime %>" defer></script>
    <script src="<%= domain %>/appjs/translate.js?<%= curentUnixTime %>"></script>
    <script>
      const categoriesContainer = document.getElementById("categories-container");
      const discountModal = document.getElementById("discount-modal");
      const discountList = document.getElementById("discount-list");
      const discountStatus = document.getElementById("discount-status");
      const notifyDiscountsButton = document.getElementById("notify-discounts-button");

      const closeDiscountModal = () => {
        discountModal.classList.add("hidden");
        discountModal.classList.remove("flex");
      };

      const loadDiscounts = async () => {
        discountList.innerHTML = `<p class="p-8 text-center text-gray-500">${i18next.t("Items.Discounts.Loading")}</p>`;
        discountStatus.textContent = "";
        notifyDiscountsButton.disabled = true;
        const response = await apiFetch("/api/v1/items/discounts");
        if (!response.ok) throw new Error("Could not load discounts");
        const { discounts } = await response.json();
        discountList.replaceChildren();
        if (discounts.length === 0) {
          discountList.innerHTML = `<p class="p-8 text-center text-gray-500">${i18next.t("Items.Discounts.Empty")}</p>`;
          return;
        }
        discounts.forEach((item) => {
          const label = document.createElement("label");
          label.className = "flex cursor-pointer items-center gap-4 p-4 hover:bg-gray-50";
          label.innerHTML = `
            <input type="checkbox" class="discount-checkbox h-5 w-5 rounded text-indigo-600" value="${item.uuid}">
            <img src="/i/items/${item.uuid}" alt="" class="h-12 w-12 rounded-lg object-cover">
            <span class="min-w-0 flex-1">
              <strong class="block truncate text-gray-900"></strong>
              <span class="text-sm text-gray-500">
                <s>${item.original_price.toFixed(2)} €</s>
                <span class="font-semibold text-red-600">${item.discount_price.toFixed(2)} €</span>
                · ${new Date(item.discount_until).toLocaleString(i18next.t("Page.LangKey"))}
              </span>
            </span>`;
          label.querySelector("strong").textContent = item.name;
          discountList.appendChild(label);
        });
      };

      const createItemCard = (item) => {
        const stockColor = item.stock < item.target_stock * 0.25 ? "text-red-500" : item.stock < item.target_stock * 0.5 ? "text-orange-500" : item.stock < item.target_stock * 0.75 ? "text-yellow-500" : "text-green-500";
        const hasActiveDiscount = Number(item.is_discounted) === 1;
        const displayPrice = hasActiveDiscount ? Number(item.discount_price) : Number(item.price);
        const priceColor = hasActiveDiscount ? "text-red-600" : "text-green-600";
        return `
        <a href="/admin/${item.uuid}/edititems" class="block">
            <div class="item-card bg-white rounded-xl shadow-lg p-4 h-full flex items-center gap-4 transition-transform transform hover:scale-105">
                <img src="/i/items/${item.uuid}" alt="${item.name}" class="w-16 h-16 md:w-20 md:h-20 object-cover rounded-lg flex-shrink-0">
                
                <div class="flex-grow flex flex-col min-w-0"> <h3 class="font-bold text-lg text-gray-800 truncate">${item.name}</h3>
                    
                    <div class="mt-2 flex items-baseline gap-4 flex-wrap">
                        <p class="${priceColor} font-semibold text-md">${displayPrice.toFixed(2).replace(".", ",")} €</p>
                        <p class="text-sm ${stockColor}">Lager: ${item.stock} / ${item.target_stock}</p>
                    </div>
                </div>
            </div>
        </a>
      `;
      };

      const createAddItemCard = (categoryName) => {
        const createUrl = `/admin/additems?category=${encodeURIComponent(categoryName)}`;
        return `
        <a href="${createUrl}" class="block h-full">
            <div class="item-card bg-white rounded-xl shadow-lg p-4 h-full flex items-center justify-start gap-4 border-2 border-dashed border-gray-300 hover:border-blue-500 hover:text-blue-500 text-gray-400 transition-colors">
                <div class="w-16 h-16 md:w-20 md:h-20 flex items-center justify-center bg-gray-50 rounded-lg flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                    </svg>
                </div>
                <span class="font-semibold text-lg" data-translate="Items.Button.Create">Neuer Artikel</span>
            </div>
        </a>
      `;
      };

      let debounceTimer;
      const debounce = (callback, time) => {
        return (...args) => {
          window.clearTimeout(debounceTimer);
          debounceTimer = setTimeout(() => {
            callback(...args);
          }, time);
        };
      };

      const loadAndRenderItems = async (searchQuery = "") => {
        categoriesContainer.innerHTML = `<p class="text-center text-gray-500">${i18next.t("Items.Loading")}</p>`;

        try {
          const url = new URL(`${window.location.origin}/api/v1/items/grouped`);
          if (searchQuery && searchQuery.trim() !== "") {
            url.searchParams.append("query", searchQuery.trim());
          }

          const response = await apiFetch(url.toString(), {
            method: "GET",
            headers: {
              "Content-Type": "application/json",
            },
          });

          if (!response.ok) throw new Error("Failed to fetch items");

          const response_json = await response.json();
          categoriesContainer.innerHTML = "";

          document.getElementById("page-title").innerText = i18next.t("Items.PageTitle", { cost: response_json.totalInventoryValue.toFixed(2).replace(".", ",") });

          // Handle case where no items are found
          if (Object.keys(response_json.groupedItems).length === 0) {
            categoriesContainer.innerHTML = `<p class="text-center text-gray-500">${i18next.t("Items.NoResults")}</p>`;
          } else {
            for (const categoryName in response_json.groupedItems) {
              const items = response_json.groupedItems[categoryName];

              const gridContainer = document.createElement("div");
              // --- THIS IS THE MODIFIED LINE ---
              gridContainer.className = "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4";

              let cardsHtml = "";
              let categoryTotalCost = 0;
              items.forEach((item) => {
                cardsHtml += createItemCard(item);
                categoryTotalCost += item.price * item.stock;
              });

              const categoryHeader = `<h2 class="text-2xl font-bold mt-8 mb-4">${i18next.t(`Categories.${categoryName}`, { cost: categoryTotalCost.toFixed(2).replace(".", ",") })}</h2>`;

              cardsHtml += createAddItemCard(categoryName);
              gridContainer.innerHTML = cardsHtml;

              categoriesContainer.innerHTML += categoryHeader;
              categoriesContainer.appendChild(gridContainer);
            }
          }
        } catch (error) {
          console.error("Failed to load items:", error);
          categoriesContainer.innerHTML = `<p class="text-red-500 text-center">${i18next.t("Items.LoadFailed")}</p>`;
        }
      };

      document.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.getElementById("search-input");
        const debouncedLoad = debounce(loadAndRenderItems, 300);

        // Add event listener to the search input
        searchInput.addEventListener("input", (event) => {
          debouncedLoad(event.target.value);
        });

        loadAndRenderItems();
        document.getElementById("open-discounts-button").addEventListener("click", async () => {
          discountModal.classList.remove("hidden");
          discountModal.classList.add("flex");
          try {
            await loadDiscounts();
          } catch (error) {
            discountList.innerHTML = `<p class="p-8 text-center text-red-500">${i18next.t("Items.Discounts.LoadFailed")}</p>`;
          }
        });
        document.getElementById("close-discounts-button").addEventListener("click", closeDiscountModal);
        document.getElementById("discount-backdrop").addEventListener("click", closeDiscountModal);
        discountList.addEventListener("change", () => {
          notifyDiscountsButton.disabled = !discountList.querySelector(".discount-checkbox:checked");
        });
        notifyDiscountsButton.addEventListener("click", async () => {
          const items = Array.from(discountList.querySelectorAll(".discount-checkbox:checked")).map((input) => input.value);
          if (items.length === 0) return;
          notifyDiscountsButton.disabled = true;
          discountStatus.textContent = i18next.t("Items.Discounts.Sending");
          const response = await apiFetch("/api/v1/items/discounts/notify", {
            method: "POST",
            body: JSON.stringify({ items }),
          });
          const result = await response.json();
          if (!response.ok) {
            discountStatus.textContent = i18next.t("Items.Discounts.SendFailed");
            notifyDiscountsButton.disabled = false;
            return;
          }
          discountStatus.textContent = i18next.t("Items.Discounts.Queued", { count: result.queued });
        });
      });
    </script>
  </body>
</html>
