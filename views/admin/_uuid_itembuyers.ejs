<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title id="pageTitle"></title>
    <%- html_content.manifest %>
    <script>
      const lang = <%- JSON.stringify(language) %>;
      const features = <%- JSON.stringify(features) %>;
      const itemUuid = <%- JSON.stringify(params.uuid) %>;
    </script>
    <script src="<%= domain %>/libjs/i18next.js?<%= curentUnixTime %>"></script>
    <script src="<%= domain %>/libjs/tailwind.js?<%= curentUnixTime %>"></script>
  </head>
  <body class="bg-gray-100">
    <%- html_content.navbar %>

    <main class="container mx-auto max-w-3xl p-4 md:p-6">
      <header class="mb-6 flex items-center gap-4">
        <a href="/admin/<%= encodeURIComponent(params.uuid) %>/edititems" class="text-gray-500 hover:text-gray-800" aria-label="Go back">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
        <h1 id="buyers-title" class="min-w-0 truncate text-2xl font-bold text-gray-800 md:text-3xl"></h1>
      </header>

      <section class="overflow-hidden rounded-xl bg-white shadow-md">
        <div class="border-b border-gray-200 p-4">
          <input
            id="buyer-search"
            type="search"
            class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-4 py-3 focus:border-indigo-500 focus:ring-indigo-500"
            data-translate-placeholder="Items.Buyers.SearchPlaceholder"
          />
        </div>

        <div id="buyers-list" class="divide-y divide-gray-100"></div>

        <div id="pagination" class="hidden items-center justify-between gap-4 border-t border-gray-200 p-4">
          <button id="previous-page" type="button" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40" data-translate="Items.Buyers.Previous"></button>
          <span id="page-info" class="text-center text-sm text-gray-500"></span>
          <button id="next-page" type="button" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40" data-translate="Items.Buyers.Next"></button>
        </div>
      </section>
    </main>

    <script src="<%= domain %>/appjs/permission.js?<%= curentUnixTime %>" defer></script>
    <script src="<%= domain %>/appjs/translate.js?<%= curentUnixTime %>"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const buyersList = document.getElementById("buyers-list");
        const searchInput = document.getElementById("buyer-search");
        const pagination = document.getElementById("pagination");
        const previousButton = document.getElementById("previous-page");
        const nextButton = document.getElementById("next-page");
        const pageInfo = document.getElementById("page-info");
        const pageSize = 20;
        let currentPage = 1;
        let searchTimer;

        const formatDate = (value) => {
          const utcTimestamp = /(?:Z|[+-]\d{2}:\d{2})$/.test(value)
            ? value
            : `${value.replace(" ", "T")}Z`;
          return new Date(utcTimestamp).toLocaleString(i18next.t("Page.LangKey"), {
            dateStyle: "medium",
            timeStyle: "short",
          });
        };

        const renderBuyer = (buyer) => {
          const row = document.createElement("a");
          row.href = `/admin/${encodeURIComponent(buyer.uuid)}/edituser`;
          row.className = "flex items-center justify-between gap-4 p-4 transition hover:bg-gray-50";

          const identity = document.createElement("div");
          identity.className = "min-w-0";

          const name = document.createElement("p");
          name.className = "truncate font-semibold text-gray-900";
          name.textContent = buyer.name;

          const username = document.createElement("p");
          username.className = "truncate text-sm text-gray-500";
          username.textContent = `@${buyer.username}`;

          const purchaseData = document.createElement("div");
          purchaseData.className = "flex-shrink-0 text-right";

          const quantity = document.createElement("p");
          quantity.className = "font-semibold text-indigo-700";
          quantity.textContent = i18next.t("Items.Buyers.Quantity", { count: buyer.quantity });

          const lastBought = document.createElement("p");
          lastBought.className = "text-xs text-gray-500";
          lastBought.textContent = i18next.t("Items.Buyers.LastBought", { date: formatDate(buyer.last_bought) });

          identity.append(name, username);
          purchaseData.append(quantity, lastBought);
          row.append(identity, purchaseData);
          return row;
        };

        const loadBuyers = async () => {
          buyersList.innerHTML = `<p class="p-8 text-center text-gray-500">${i18next.t("Items.Buyers.Loading")}</p>`;
          pagination.classList.add("hidden");

          const params = new URLSearchParams({
            search: searchInput.value.trim(),
            page: String(currentPage),
            limit: String(pageSize),
          });

          try {
            const response = await apiFetch(`/api/v1/items/buyers/${encodeURIComponent(itemUuid)}?${params}`);
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            const result = await response.json();

            document.getElementById("buyers-title").textContent = i18next.t("Items.Buyers.Title", { item: result.item.name });
            buyersList.replaceChildren();

            if (result.buyers.length === 0) {
              buyersList.innerHTML = `<p class="p-8 text-center text-gray-500">${i18next.t("Items.Buyers.NoResults")}</p>`;
              return;
            }

            result.buyers.forEach((buyer) => buyersList.appendChild(renderBuyer(buyer)));
            const totalPages = Math.max(result.pagination.totalPages, 1);
            pageInfo.textContent = i18next.t("Items.Buyers.PageInfo", { page: currentPage, totalPages });
            previousButton.disabled = currentPage <= 1;
            nextButton.disabled = currentPage >= totalPages;
            pagination.classList.remove("hidden");
            pagination.classList.add("flex");
          } catch (error) {
            console.error("Failed to load item buyers:", error);
            buyersList.innerHTML = `<p class="p-8 text-center text-red-500">${i18next.t("Items.Buyers.LoadFailed")}</p>`;
          }
        };

        searchInput.addEventListener("input", () => {
          clearTimeout(searchTimer);
          searchTimer = setTimeout(() => {
            currentPage = 1;
            loadBuyers();
          }, 300);
        });

        previousButton.addEventListener("click", () => {
          if (currentPage <= 1) return;
          currentPage--;
          loadBuyers();
        });

        nextButton.addEventListener("click", () => {
          currentPage++;
          loadBuyers();
        });

        loadBuyers();
      });
    </script>
  </body>
</html>
