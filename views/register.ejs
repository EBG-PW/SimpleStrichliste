<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title id="pageTitle" data-translate="Setup.WelcomeUser"></title>
    <%- html_content.manifest %>
    <script>
      const lang = <%- JSON.stringify(language) %>
      const features = <%- JSON.stringify(features) %>
    </script>
    <script src="<%= domain %>/libjs/i18next.js?<%= curentUnixTime %>"></script>
    <script src="<%= domain %>/libjs/tailwind.js?<%= curentUnixTime %>"></script>
  </head>

  <body class="bg-gray-100 font-sans flex flex-col min-h-screen">
    <main class="flex-grow flex flex-col items-center justify-center p-4">
      <div id="reg-container" class="w-full max-w-md">
        <div class="text-gray-500">
          <div id="registration-card" class="<% if (Object.values(features || {}).some((feature) => feature.registration?.takeover)) { %>hidden <% } %>bg-white rounded-xl shadow-lg p-8">
            <div class="text-center mb-8">
              <h1 class="text-2xl font-bold text-gray-800" data-translate="Setup.WelcomeUser"></h1>
              <p class="text-gray-600 mt-2" data-translate="Setup.WelcomeDescriptionUser"></p>
            </div>
            <% if (ebgOAuth.enabled && !Object.values(features || {}).some((feature) => feature.registration?.takeover)) { %>
            <a id="oauth-register-link" href="/auth/oauth" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-translate="Setup.Form.OAuthSubmit">
            </a>
            <% } else if (ebgOAuth.enabled) { %>
            <div id="oauth-registration-feedback" class="text-center text-sm text-red-600"></div>
            <% } else { %>
            <form id="reg-form" class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700" data-translate="Setup.Form.Name"></label>
                <input type="text" id="name" name="name" required class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700" data-translate="Setup.Form.Email"></label>
                <input type="email" id="email" name="email" required class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
              </div>
              <div>
                <label for="username" class="block text-sm font-medium text-gray-700" data-translate="Setup.Form.Username"></label>
                <input type="text" id="username" name="username" required class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
              </div>
              <div>
                <label for="password" class="block text-sm font-medium text-gray-700" data-translate="Setup.Form.Password"></label>
                <input type="password" id="password" name="password" required class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
              </div>
              <div>
                <label for="password-repeat" class="block text-sm font-medium text-gray-700" data-translate="Setup.Form.PasswordRepeat"></label>
                <input type="password" id="password-repeat" name="password-repeat" required class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
              </div>
              <div>
                <label for="reg_code" class="block text-sm font-medium text-gray-700 hidden" data-translate="Setup.Form.RegCode"></label>
                <input type="text" id="reg_code" name="reg_code" class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 hidden" />
              </div>
              <div id="registration-feature-root" class="space-y-3"></div>
              <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-translate="Setup.Form.Submit"></button>
            </form>
            <div id="form-feedback" class="mt-4 text-center"></div>
            <% } %>
          </div>
        </div>
      </div>
    </main>

    <%- html_content.footer %>

    <script src="<%= domain %>/appjs/translate.js?<%= curentUnixTime %>"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const regContainer = document.getElementById("reg-container");
        const registrationFeatureHandlers = [];
        const isOAuthEnabled = <%- JSON.stringify(ebgOAuth.enabled) %>;
        const hasRegistrationTakeover = <%- JSON.stringify(Object.values(features || {}).some((feature) => feature.registration?.takeover)) %>;

        const urlParams = new URLSearchParams(window.location.search);
        const regCodeFromUrl = urlParams.get("REGCODE");
        const regCodeInput = document.getElementById("reg_code");
        if (regCodeFromUrl && regCodeInput) {
          regCodeInput.value = regCodeFromUrl;
        }

        function loadScript(src) {
          return new Promise((resolve, reject) => {
            const script = document.createElement("script");
            script.src = `${src}?<%= curentUnixTime %>`;
            script.onload = resolve;
            script.onerror = () => reject(new Error(`Failed to load ${src}`));
            document.head.appendChild(script);
          });
        }

        async function loadRegistrationFeatures() {
          const root = document.getElementById("registration-feature-root");
          for (const [featureName, feature] of Object.entries(features || {})) {
            if (!feature.registration?.script) continue;
            await loadScript(feature.registration.script);
            const handler = window.SimpleStrichlisteRegistrationFeatures?.[featureName];
            if (!handler || typeof handler.collect !== "function") continue;
            if (typeof handler.mountStandalone === "function") {
              document.getElementById("registration-card").classList.add("hidden");
              regContainer.className = "w-full max-w-md";
              const container = document.createElement("div");
              regContainer.appendChild(container);
              await handler.mountStandalone({
                container,
                feature,
                regCode: regCodeInput?.value || "",
                oauthMode: isOAuthEnabled,
                t: (key, options) => i18next.t(key, options),
                submitRegistration: isOAuthEnabled ? submitOAuthRegistration : submitRegistration,
              });
              return true;
            }
            const container = document.createElement("div");
            if (!root) continue;
            root.appendChild(container);
            if (typeof handler.mount === "function") {
              await handler.mount({ container, feature, t: (key, options) => i18next.t(key, options) });
            }
            registrationFeatureHandlers.push({ featureName, payloadKey: feature.registration.payloadKey || featureName, handler });
          }
          return false;
        }

        async function collectRegistrationFeatures() {
          const payload = {};
          for (const registrationFeature of registrationFeatureHandlers) {
            payload[registrationFeature.payloadKey] = await registrationFeature.handler.collect();
          }
          return payload;
        }

        async function submitRegistration(payload) {
          const response = await fetch("/api/v1/users", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          const response_json = await response.json();

          if (response.ok) {
            regContainer.innerHTML = `
              <div class="bg-white rounded-xl shadow-lg p-8 text-center">
                <h1 class="text-2xl font-bold text-green-600">${i18next.t("Setup.UserCreated")}</h1>
                <p class="text-gray-600 mt-2">${i18next.t("Setup.UserCreatedDescription")}</p>
                <a href="/login" class="mt-4 inline-block py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700">Zum Login</a>
              </div>`;
            return { ok: true, response, body: response_json };
          }

          if (response.status === 500) throw new Error(i18next.t("Error.UnknownError"));
          if (response.status === 403) {
            const error = new Error(i18next.t("Setup.Error.InvalidRegCode"));
            error.status = 403;
            throw error;
          }
          if (response.status === 405) {
            window.location.href = "/setup";
            return { ok: false, response, body: response_json };
          }
          if (response.status === 409) {
            const error = new Error(i18next.t("Setup.Error.UserExists"));
            error.status = 409;
            throw error;
          }
          if (typeof response_json.reason === "string") {
            const error = new Error(translateApiError(response_json));
            error.status = response.status;
            throw error;
          }
          const error = new Error(translateValidationError(response_json, "Setup.Form"));
          error.status = response.status;
          error.body = response_json;
          throw error;
        }

        async function submitOAuthRegistration(payload) {
          const response = await fetch("/auth/oauth/registration-context", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              features: payload.features || {},
            }),
          });

          const response_json = await response.json();
          if (!response.ok) {
            const error = new Error(typeof response_json.reason === "string"
              ? translateApiError(response_json)
              : translateValidationError(response_json, "Setup.Form"));
            error.status = response.status;
            throw error;
          }

          window.location.href = response_json.redirectUrl || "/auth/oauth";
          return { ok: true, response, body: response_json };
        }

        // Attach event listener to the form
        loadRegistrationFeatures()
          .catch((error) => {
            if (!isOAuthEnabled || !hasRegistrationTakeover) {
              document.getElementById("registration-card").classList.remove("hidden");
            }
            const feedback = document.getElementById("oauth-registration-feedback");
            if (feedback) feedback.textContent = error.message;
            showMessage(error.message, "error");
          })
          .then((handled) => {
            if (!handled) {
              document.getElementById("registration-card").classList.remove("hidden");
              if (!isOAuthEnabled) document.getElementById("reg-form").addEventListener("submit", handleFormSubmit);
            }
          });

        /**
         * Handles the submission of the reg form.
         */
        async function handleFormSubmit(event) {
          event.preventDefault();
          const form = event.target;
          const feedbackDiv = document.getElementById("form-feedback");
          const submitButton = form.querySelector('button[type="submit"]');

          submitButton.disabled = true;
          feedbackDiv.innerHTML = "";

          try {
            if (form.password.value !== form["password-repeat"].value) {
              throw new Error(i18next.t("Setup.Error.PasswordMismatch"));
            }
            const result = await submitRegistration({
                name: form.name.value,
                email: form.email.value,
                username: form.username.value,
                password: form.password.value,
                reg_code: form.reg_code.value,
                features: await collectRegistrationFeatures(),
            });

            if (!result.ok) {
              const response = result.response;
              const response_json = result.body;
              if (response.status === 500) throw new Error(i18next.t("Error.UnknownError"));

              if (response.status === 403) {
                const regCodeLabel = document.querySelector('label[for="reg_code"]');
                regCodeLabel.classList.remove("hidden");
                regCodeInput.classList.remove("hidden");
                throw new Error(i18next.t("Setup.Error.InvalidRegCode"));
              }

              // Forward to /setup if the application is not setup yet
              if (response.status === 405) {
                window.location.href = "/setup";
                return;
              }

              if (response.status === 409) throw new Error(i18next.t("Setup.Error.UserExists"));

              if (typeof response_json.reason === "string") {
                showMessage(translateApiError(response_json), "error");
                submitButton.disabled = false;
                return;
              }
              const input_name = response_json.reason[0].path[0];
              const keys = {
                name: "name",
                email: "email",
                username: "username",
                password: "password",
                reg_code: "reg_code",
              };
              for (const key in keys) {
                document.getElementById(keys[key]).classList.remove("is-invalid");
              }

              showMessage(translateValidationError(response_json, "Setup.Form"), "error");
              document.getElementById(keys[input_name]).classList.add("is-invalid");
              submitButton.disabled = false;
            }
          } catch (error) {
            if (error.status === 403) {
              const regCodeLabel = document.querySelector('label[for="reg_code"]');
              regCodeLabel.classList.remove("hidden");
              regCodeInput.classList.remove("hidden");
            }
            showMessage(error.message, "error");
            submitButton.disabled = false;
          }
        }
      });
    </script>
  </body>
</html>
