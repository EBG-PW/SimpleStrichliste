<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title id="pageTitle" data-translate="Items.HistoryHeader"></title>
    <%- html_content.manifest %>
    <script>
      const lang = <%- JSON.stringify(language) %>;
      const features = <%- JSON.stringify(features) %>;
      const transactionHistoryFormatters = <%- JSON.stringify(Object.fromEntries(Object.entries(features || {})
        .map(([featureName, feature]) => [featureName, feature?.transactionHistory?.customItemText])
        .filter(([, formatter]) => formatter?.template && typeof formatter.template === "string"))) %>;
    </script>
    <script src="<%= domain %>/libjs/i18next.js?<%= curentUnixTime %>"></script>
    <script src="<%= domain %>/libjs/tailwind.js?<%= curentUnixTime %>"></script>
    <style>
      body {
        padding-bottom: 80px;
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .transaction-item {
        animation: fadeIn 0.3s ease-out forwards;
      }
      .loader {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #3498db;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
        margin: 20px auto;
      }
      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }
    </style>
  </head>
  <body class="bg-gray-50 font-sans">
    <%- html_content.navbar %>

    <div id="app-container" class="max-w-2xl mx-auto p-4">
      <header class="flex items-center justify-between mb-6">
        <a href="/overview" class="p-2 rounded-md hover:bg-gray-200 transition-colors" aria-label="Back to store">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-700" fill="none" viewBox="0 0 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        <h1 id="pageHeader" class="text-2xl font-bold text-gray-800"></h1>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-600" id="groupByDayLabel"></span>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="groupByDayToggle" class="sr-only peer" />
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
          </label>
        </div>
      </header>

      <main id="transactions-container"></main>

      <div id="loading-indicator" class="hidden">
        <div class="loader"></div>
      </div>
    </div>

    <div id="refund-modal-overlay" class="fixed inset-0 z-50 hidden items-center justify-center bg-black bg-opacity-60 p-4">
      <div class="w-full max-w-md rounded-xl bg-white p-6 shadow-xl">
        <h2 class="text-xl font-bold text-gray-800" data-translate="Items.RefundModalTitle"></h2>
        <p class="mt-3 text-gray-600" data-translate="Items.RefundConfirm"></p>
        <div class="mt-6 flex justify-end gap-3">
          <button type="button" id="refund-cancel-button" class="rounded-lg bg-gray-200 px-4 py-2 font-semibold text-gray-700 hover:bg-gray-300" data-translate="Items.Button.Cancel"></button>
          <button type="button" id="refund-confirm-button" class="rounded-lg bg-red-600 px-4 py-2 font-semibold text-white hover:bg-red-700" data-translate="Items.Refund"></button>
        </div>
      </div>
    </div>

    <script src="<%= domain %>/appjs/permission.js?<%= curentUnixTime %>" defer></script>
    <script src="<%= domain %>/appjs/translate.js?<%= curentUnixTime %>"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const transactionsContainer = document.getElementById("transactions-container");
        const loadingIndicator = document.getElementById("loading-indicator");
        const groupByDayToggle = document.getElementById('groupByDayToggle');
        const groupByDayLabel = document.getElementById('groupByDayLabel');

        document.getElementById("pageHeader").textContent = i18next.t("Items.HistoryHeader");
        groupByDayLabel.textContent = i18next.t('Items.GroupByDay');

        let currentPage = 1;
        const ITEMS_PER_PAGE = 20;
        let isLoading = false;
        let hasMoreData = true;
        let groupByDay = localStorage.getItem('groupByDay') === 'true';
        let pendingRefundTransactionId = null;
        groupByDayToggle.checked = groupByDay;

        groupByDayToggle.addEventListener('change', () => {
            groupByDay = groupByDayToggle.checked;
            currentPage = 1;
            hasMoreData = true;
            transactionsContainer.innerHTML = '';
            loadTransactions();
            localStorage.setItem('groupByDay', groupByDay);
        });

        const formatTimestamp = (isoString) => {
          const utcTimestamp = /(?:Z|[+-]\d{2}:\d{2})$/.test(isoString)
            ? isoString
            : `${isoString.replace(" ", "T")}Z`;
          const date = new Date(utcTimestamp);
          return {
            date: date.toLocaleDateString(t("Page.LangKey"), { year: "numeric", month: "long", day: "numeric" }),
            time: date.toLocaleTimeString(t("Page.LangKey"), { hour: "2-digit", minute: "2-digit" }),
          };
        };

        const escapeHTML = (value) => String(value ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");

        const formatCustomItemText = (value) => {
          if (!value) return "";
          try {
            const payload = JSON.parse(value);
            const formatter = payload?.feature ? transactionHistoryFormatters[payload.feature] : null;
            if (formatter?.template) {
              const formatted = formatter.template.replace(/\{([^}]+)\}/g, (match, expression) => {
                const keys = expression.split("|").map((key) => key.trim()).filter(Boolean);
                const replacement = keys.map((key) => payload[key]).find((candidate) => candidate !== undefined && candidate !== null && candidate !== "");
                return replacement === undefined ? "" : String(replacement);
              }).replace(/\s+/g, " ").trim();

              if (formatted) return escapeHTML(formatted);
            }
          } catch (error) {
            // Old custom text was stored as plain text.
          }
          return escapeHTML(value);
        };

        const createTransactionHTML = (tx) => {
          const { time } = formatTimestamp(tx.transaction_timestamp);
          let totalAmount = tx.price_at_transaction * tx.quantity;
          const isRefunded = Number(tx.status) === 1;

          let transaction_type;
          let iconOrImage;
          let title;
          switch (tx.item_uuid) {
            case "13620506-b9f8-44d7-a9ff-d1b58ddee93f": // System
              transaction_type = "purchase";
              if (tx.custom_item_text) {
                totalAmount = totalAmount * -1;
                title = formatCustomItemText(tx.custom_item_text);
              } else {
                title = i18next.t("Items.SystemTransaction");
              }
              iconOrImage = `<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-gray-100 rounded-full">
                           <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                       </div>`;
              break;
            case "80a38ccf-013f-404f-9099-b2a63e958aa8": // Restock (Purchase was made and added via restock)
              transaction_type = "restock";
              title = i18next.t("Items.SystemPurchase");
              iconOrImage = `<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-gray-100 rounded-full">
                            <svg  xmlns="http://www.w3.org/2000/svg"  width="24"  height="24"  viewBox="0 0 24 24"  fill="none"  stroke="currentColor"  stroke-width="2"  stroke-linecap="round"  stroke-linejoin="round"  class="icon icon-tabler icons-tabler-outline icon-tabler-shopping-cart"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M6 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M17 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M17 17h-11v-14h-2" /><path d="M6 5l14 1l-1 7h-13" /></svg>
                       </div>`;
              break;
            default:
              transaction_type = "purchase";
              totalAmount = totalAmount * -1; // Invert amount for purchases
              title = escapeHTML(i18next.t("Items.PurchaseTitle", { count: tx.quantity, name: tx.item_name }));
              iconOrImage = `<img src="/i/items/${encodeURIComponent(tx.item_uuid)}" alt="${escapeHTML(tx.item_name)}" class="w-12 h-12 object-cover rounded-full">`;
          }

          const sign = totalAmount > 0 ? "+" : totalAmount < 0 ? "-" : "";
          const amountColor = totalAmount > 0 ? "text-green-600" : totalAmount < 0 ? "text-red-600" : "text-gray-600";
          const displayAmount = Math.abs(totalAmount).toFixed(2);
          const canRefund = Boolean(tx.id && Number(tx.can_refund) === 1 && !isRefunded);
          const refundButton = canRefund
            ? `<button type="button" onclick="refundTransaction(${Number(tx.id)})" class="mt-1 rounded border border-red-200 px-2 py-1 text-xs font-semibold text-red-700 hover:bg-red-50">${i18next.t("Items.Refund")}</button>`
            : "";
          const refundedLabel = isRefunded
            ? `<p class="mt-1 text-xs font-semibold text-gray-500">${i18next.t("Items.Refunded")}</p>`
            : "";
          const refundedClass = isRefunded ? "opacity-60 line-through" : "";

          return `
                    <div class="transaction-item flex items-center justify-between p-3 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200">
                        <div class="flex items-center gap-4 min-w-0 ${refundedClass}">
                            ${iconOrImage}
                            <div class="min-w-0">
                                <p class="font-semibold text-gray-800 truncate">${title}</p>
                                <p class="text-xs text-gray-400">${i18next.t("Items.AuthorizedBy", { name: tx.initiator_name, username: tx.initiator_username, time })}</p>
                            </div>
                        </div>
                        <div class="text-right flex-shrink-0 ml-2">
                            <p class="font-bold text-lg ${amountColor} ${refundedClass}">${i18next.t("Items.HistoryAmmount", { amount: displayAmount, sign: sign })}</p>
                            ${refundedLabel}
                            ${refundButton}
                        </div>
                    </div>
                `;
        };

        const openRefundModal = (transactionId) => {
          pendingRefundTransactionId = transactionId;
          document.getElementById("refund-modal-overlay").classList.remove("hidden");
          document.getElementById("refund-modal-overlay").classList.add("flex");
        };

        const closeRefundModal = () => {
          pendingRefundTransactionId = null;
          document.getElementById("refund-modal-overlay").classList.add("hidden");
          document.getElementById("refund-modal-overlay").classList.remove("flex");
        };

        window.refundTransaction = (transactionId) => {
          openRefundModal(transactionId);
        };

        const confirmRefundTransaction = async () => {
          const transactionId = pendingRefundTransactionId;
          if (!transactionId) return;

          try {
            document.getElementById("refund-confirm-button").disabled = true;
            const response = await apiFetch(`/api/v1/transactions/${encodeURIComponent(transactionId)}/refund`, {
              method: "POST",
            });

            if (!response.ok) throw new Error("Refund failed");

            if (typeof showMessage === "function") showMessage(i18next.t("Items.RefundSuccess"));
            currentPage = 1;
            hasMoreData = true;
            transactionsContainer.innerHTML = "";
            closeRefundModal();
            await loadTransactions();
          } catch (error) {
            console.error("Refund failed:", error);
            if (typeof showMessage === "function") showMessage(i18next.t("Items.RefundError"), "error");
          } finally {
            document.getElementById("refund-confirm-button").disabled = false;
          }
        };

        document.getElementById("refund-cancel-button").addEventListener("click", closeRefundModal);
        document.getElementById("refund-modal-overlay").addEventListener("click", (event) => {
          if (event.target.id === "refund-modal-overlay") closeRefundModal();
        });
        document.getElementById("refund-confirm-button").addEventListener("click", confirmRefundTransaction);

        const loadTransactions = async () => {
          if (isLoading || !hasMoreData) return;
          isLoading = true;

          if (currentPage === 1) {
            transactionsContainer.innerHTML = '<div class="loader"></div>';
          } else {
            loadingIndicator.classList.remove("hidden");
          }

          try {
            const response = await apiFetch(`/api/v1/transactions?page=${currentPage}&limit=${ITEMS_PER_PAGE}&groupbyday=${groupByDay}`);
            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

            const result = await response.json();
            let newTransactions;

            if (result && Array.isArray(result.transactions)) {
              newTransactions = result.transactions;
            } else {
              console.error("API response is not in the expected format:", result);
              newTransactions = [];
            }

            if (currentPage === 1) {
              transactionsContainer.innerHTML = "";
            }

            if (newTransactions.length === 0 && currentPage === 1) {
              transactionsContainer.innerHTML = `<p class="text-center text-gray-500">${i18next.t("Items.NoTransactions")}</p>`;
              hasMoreData = false;
              return;
            }

            if (newTransactions.length < ITEMS_PER_PAGE) {
              hasMoreData = false;
            }

            const groupedByDay = newTransactions.reduce((acc, tx) => {
              const { date } = formatTimestamp(tx.transaction_timestamp);
              if (!acc[date]) acc[date] = [];
              acc[date].push(tx);
              return acc;
            }, {});

            for (const date in groupedByDay) {
              let dayGroupContainer = transactionsContainer.querySelector(`.day-group[data-date="${date}"]`);
              if (!dayGroupContainer) {
                const dayGroupHtml = `
                                <div class="day-group mb-6" data-date="${date}">
                                    <h2 class="text-lg font-bold text-gray-700 my-3 px-1">${date}</h2>
                                    <div class="transactions-for-day flex flex-col gap-3"></div>
                                </div>`;
                transactionsContainer.insertAdjacentHTML("beforeend", dayGroupHtml);
                dayGroupContainer = transactionsContainer.querySelector(`.day-group[data-date="${date}"]`);
              }
              const listElement = dayGroupContainer.querySelector(".transactions-for-day");
              const newItemsHtml = groupedByDay[date].map(createTransactionHTML).join("");
              listElement.insertAdjacentHTML("beforeend", newItemsHtml);
            }

            currentPage++;
          } catch (error) {
            console.error("Failed to load transactions:", error);
            transactionsContainer.innerHTML = `<p class="text-center text-red-500">${i18next.t("Items.HistoryError")}</p>`;
          } finally {
            isLoading = false;
            loadingIndicator.classList.add("hidden");
          }
        };

        window.addEventListener("scroll", () => {
          const isNearBottom = window.innerHeight + window.scrollY >= document.body.offsetHeight - 300;
          if (isNearBottom) {
            loadTransactions();
          }
        });

        // Initial load
        loadTransactions();
      });
    </script>
  </body>
</html>
